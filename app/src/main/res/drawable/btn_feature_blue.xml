<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#0A2A4A"/>
            <corners android:radius="14dp"/>
            <stroke android:width="2dp" android:color="#4488FF"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0A1A2E"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#224488"/>
        </shape>
    </item>
</selector>
