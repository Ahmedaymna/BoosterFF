<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient android:startColor="#1A6B3A" android:endColor="#0D4A28" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:startColor="#1DB954" android:endColor="#158A3E" android:angle="135"/>
            <corners android:radius="14dp"/>
            <stroke android:width="1dp" android:color="#FFFFFF33"/>
        </shape>
    </item>
</selector>
